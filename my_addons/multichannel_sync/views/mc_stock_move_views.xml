<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Search view ─────────────────────────────────────────────────── -->
    <record id="view_mc_stock_move_search" model="ir.ui.view">
        <field name="name">mc.stock.move.search</field>
        <field name="model">mc.stock.move</field>
        <field name="arch" type="xml">
            <search string="Search Stock Moves">
                <field name="product_id"/>
                <field name="reference"/>
                <field name="channel_id"/>
                <filter name="in"         string="Stock In"     domain="[('move_type','=','in')]"/>
                <filter name="out"        string="Stock Out"    domain="[('move_type','=','out')]"/>
                <filter name="adjustment" string="Adjustments"  domain="[('move_type','=','adjustment')]"/>
                <separator/>
                <filter name="today" string="Today"
                    domain="[('move_date','&gt;=',(context_today()).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="1" string="Group By">
                    <filter name="group_product"  string="Product"   context="{'group_by': 'product_id'}"/>
                    <filter name="group_channel"  string="Channel"   context="{'group_by': 'channel_id'}"/>
                    <filter name="group_type"     string="Move Type" context="{'group_by': 'move_type'}"/>
                    <filter name="group_date"     string="Date"      context="{'group_by': 'move_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Tree/List view ─────────────────────────────────────────────── -->
    <record id="view_mc_stock_move_tree" model="ir.ui.view">
        <field name="name">mc.stock.move.tree</field>
        <field name="model">mc.stock.move</field>
        <field name="arch" type="xml">
            <tree string="Stock Moves"
                create="false"
                delete="false"
                decoration-success="move_type == 'in'"
                decoration-danger="move_type == 'out'"
                decoration-info="move_type == 'adjustment'">
                <field name="move_date"/>
                <field name="product_id"/>
                <field name="move_type" widget="badge"
                    decoration-success="move_type == 'in'"
                    decoration-danger="move_type == 'out'"
                    decoration-info="move_type == 'adjustment'"/>
                <field name="quantity"/>
                <field name="signed_quantity" optional="show"/>
                <field name="channel_id"/>
                <field name="reference"/>
                <field name="note" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- ── Graph view: signed quantity over time ────────────────────────── -->
    <record id="view_mc_stock_move_graph" model="ir.ui.view">
        <field name="name">mc.stock.move.graph</field>
        <field name="model">mc.stock.move</field>
        <field name="arch" type="xml">
            <graph string="Stock Movement History" type="bar">
                <field name="move_date" type="row" interval="day"/>
                <field name="signed_quantity" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ── Window action ──────────────────────────────────────────────── -->
    <record id="action_mc_stock_move" model="ir.actions.act_window">
        <field name="name">Stock Moves</field>
        <field name="res_model">mc.stock.move</field>
        <field name="view_mode">tree,graph</field>
        <field name="search_view_id" ref="view_mc_stock_move_search"/>
        <field name="context">{'search_default_group_product': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No stock movements yet.</p>
            <p>Stock movements are created automatically when orders are confirmed or cancelled.</p>
        </field>
    </record>

</odoo>
