<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mc_raw_order_tree_integration" model="ir.ui.view">
        <field name="name">mc.raw.order.tree.integration</field>
        <field name="model">mc.raw.order</field>
        <field name="inherit_id" ref="mc_sale_order.view_mc_raw_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="canonical_order_status" widget="badge"/>
                <field name="canonical_payment_status" widget="badge"/>
                <field name="mapping_status" widget="badge"/>
                <field name="reconcile_state" widget="badge"/>
            </xpath>
        </field>
    </record>

    <record id="view_mc_raw_order_form_integration" model="ir.ui.view">
        <field name="name">mc.raw.order.form.integration</field>
        <field name="model">mc.raw.order</field>
        <field name="inherit_id" ref="mc_sale_order.view_mc_raw_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sale_order_id']" position="after">
                <field name="integration_event_id"/>
                <field name="normalized_at"/>
                <field name="mapping_status" widget="badge"/>
                <field name="mapped_product_count"/>
            </xpath>
            <xpath expr="//notebook/page[field[@name='error_message']]" position="before">
                <page string="Đối soát trạng thái">
                    <group>
                        <group>
                            <field name="platform_order_status"/>
                            <field name="platform_payment_status"/>
                            <field name="platform_status_updated_at"/>
                        </group>
                        <group>
                            <field name="canonical_order_status"/>
                            <field name="canonical_payment_status"/>
                            <field name="reconcile_state"/>
                            <field name="reconciled_at"/>
                        </group>
                    </group>
                    <field name="reconcile_message" nolabel="1"/>
                </page>
                <page string="Map SKU">
                    <group>
                        <field name="mapping_status"/>
                        <field name="mapped_product_count"/>
                    </group>
                    <field name="unmapped_skus" placeholder="Các SKU chưa được map sẽ hiện ở đây."/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_mc_raw_order_search_integration" model="ir.ui.view">
        <field name="name">mc.raw.order.search.integration</field>
        <field name="model">mc.raw.order</field>
        <field name="inherit_id" ref="mc_sale_order.view_mc_raw_order_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='error']" position="after">
                <filter name="mapped" string="Đã map" domain="[('mapping_status','=','mapped')]"/>
                <filter name="unmapped" string="Chưa map" domain="[('mapping_status','in',('partial','unmapped'))]"/>
                <filter name="reconciled" string="Đã đối soát" domain="[('reconcile_state','=','matched')]"/>
                <filter name="mismatched" string="Lệch trạng thái" domain="[('reconcile_state','=','mismatched')]"/>
            </xpath>
            <xpath expr="//filter[@name='group_state']" position="after">
                <filter name="group_mapping_status" string="Trạng thái Map" context="{'group_by': 'mapping_status'}"/>
                <filter name="group_canonical_order_status" string="Trạng thái Đơn" context="{'group_by': 'canonical_order_status'}"/>
                <filter name="group_reconcile_state" string="Trạng thái Đối soát" context="{'group_by': 'reconcile_state'}"/>
            </xpath>
        </field>
    </record>
</odoo>
