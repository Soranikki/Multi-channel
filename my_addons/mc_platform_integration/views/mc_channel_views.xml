<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mc_channel_form_integration" model="ir.ui.view">
        <field name="name">mc.channel.form.integration</field>
        <field name="model">mc.channel</field>
        <field name="inherit_id" ref="mc_core.view_mc_channel_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="before">
                <group string="Realtime Integration">
                    <group>
                        <field name="integration_enabled"/>
                        <field name="middleware_channel_key"/>
                    </group>
                    <group>
                        <field name="auto_parse_orders"/>
                        <field name="auto_check_mapping"/>
                        <field name="auto_process_orders"/>
                        <field name="auto_reconcile_orders"/>
                        <field name="last_realtime_received_at"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
