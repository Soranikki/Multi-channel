<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_product_form_mc" model="ir.ui.view">
        <field name="name">product.product.form.mc</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_mc_mappings" type="object" class="oe_stat_button" icon="fa-link">
                    <field name="mc_mapping_count" widget="statinfo" string="MC Mappings"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='default_code']" position="after">
                <field name="mc_low_stock_threshold"/>
                <field name="mc_is_low_stock" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_product_tree_mc" model="ir.ui.view">
        <field name="name">product.product.tree.mc</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="decoration-danger">mc_is_low_stock == True</attribute>
            </xpath>
            <xpath expr="//field[@name='default_code']" position="after">
                <field name="mc_low_stock_threshold" optional="hide"/>
                <field name="mc_is_low_stock" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
