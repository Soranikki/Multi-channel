<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mc_product_mapping_search" model="ir.ui.view">
        <field name="name">mc.product.mapping.search</field>
        <field name="model">mc.product.mapping</field>
        <field name="arch" type="xml">
            <search string="Product Mappings">
                <field name="external_sku"/>
                <field name="external_name"/>
                <field name="product_id"/>
                <field name="channel_id"/>
                <filter name="active" string="Active" domain="[('is_active','=',True)]"/>
                <filter name="inactive" string="Inactive" domain="[('is_active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_channel" string="Channel" context="{'group_by': 'channel_id'}"/>
                    <filter name="group_product" string="Product" context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_mc_product_mapping_tree" model="ir.ui.view">
        <field name="name">mc.product.mapping.tree</field>
        <field name="model">mc.product.mapping</field>
        <field name="arch" type="xml">
            <tree string="Product Mappings" editable="bottom" decoration-muted="is_active == False" decoration-danger="mc_is_low_stock == True">
                <field name="channel_id"/>
                <field name="external_sku"/>
                <field name="external_name"/>
                <field name="product_id"/>
                <field name="internal_sku" readonly="1"/>
                <field name="qty_available" readonly="1"/>
                <field name="virtual_available" readonly="1"/>
                <field name="mc_is_low_stock" readonly="1" optional="hide"/>
                <field name="is_active"/>
            </tree>
        </field>
    </record>

    <record id="view_mc_product_mapping_form" model="ir.ui.view">
        <field name="name">mc.product.mapping.form</field>
        <field name="model">mc.product.mapping</field>
        <field name="arch" type="xml">
            <form string="Product Mapping">
                <sheet>
                    <group>
                        <group string="Channel">
                            <field name="channel_id"/>
                            <field name="channel_code" readonly="1"/>
                            <field name="is_active"/>
                        </group>
                        <group string="Product">
                            <field name="product_id"/>
                            <field name="internal_sku" readonly="1"/>
                            <field name="qty_available" readonly="1"/>
                            <field name="virtual_available" readonly="1"/>
                        </group>
                    </group>
                    <group string="External Platform">
                        <field name="external_sku"/>
                        <field name="external_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mc_product_mapping" model="ir.actions.act_window">
        <field name="name">Product Mappings</field>
        <field name="res_model">mc.product.mapping</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_mc_product_mapping_search"/>
        <field name="context">{'search_default_active': 1, 'search_default_group_channel': 1}</field>
    </record>
</odoo>
