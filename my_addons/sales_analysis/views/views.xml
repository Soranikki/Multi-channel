<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sales_analysis_search" model="ir.ui.view">
        <field name="name">sales.analysis.search</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <search string="Sales Analysis">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="team_id"/>
                <field name="product_tmpl_id"/>
                <field name="categ_id"/>
                <filter name="filter_confirmed" string="Confirmed Orders" domain="[('state', '=', 'sale')]"/>
                <filter name="filter_quotations" string="Quotations" domain="[('state', 'in', ('draft', 'sent'))]"/>
                <filter name="filter_to_invoice" string="To Invoice" domain="[('invoice_status', '=', 'to invoice')]"/>
                <filter name="filter_fully_invoiced" string="Fully Invoiced" domain="[('invoice_status', '=', 'invoiced')]"/>
                <separator/>
                <filter name="current_year" string="This Year" date="date" default_period="this_year"/>
                <filter name="current_month" string="This Month" date="date" default_period="this_month"/>
                <filter name="current_quarter" string="This Quarter" date="date" default_period="this_quarter"/>
                <separator/>
                <filter name="my_sales" string="My Sales" domain="[('user_id', '=', uid)]"/>
                <group expand="0" string="Extended Filters">
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="country_id"/>
                    <field name="industry_id"/>
                    <field name="state"/>
                    <field name="invoice_status"/>
                </group>
                <group expand="1" string="Group By">
                    <filter name="group_by_month" string="Month" context="{'group_by': 'date:month'}"/>
                    <filter name="group_by_salesperson" string="Salesperson" context="{'group_by': 'user_id'}"/>
                    <filter name="group_by_team" string="Sales Team" context="{'group_by': 'team_id'}"/>
                    <filter name="group_by_customer" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_by_country" string="Country" context="{'group_by': 'country_id'}"/>
                    <filter name="group_by_product" string="Product" context="{'group_by': 'product_tmpl_id'}"/>
                    <filter name="group_by_category" string="Category" context="{'group_by': 'categ_id'}"/>
                    <filter name="group_by_status" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sales_analysis_tree" model="ir.ui.view">
        <field name="name">sales.analysis.tree</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <tree string="Sales Analysis" default_order="date desc">
                <field name="date" widget="date"/>
                <field name="order_reference" string="Order"/>
                <field name="partner_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="team_id" optional="show"/>
                <field name="product_tmpl_id" string="Product" optional="show"/>
                <field name="categ_id" optional="hide"/>
                <field name="product_uom_qty" string="Ordered Qty" sum="Total Ordered Qty"/>
                <field name="qty_delivered" sum="Total Delivered Qty" optional="hide"/>
                <field name="qty_to_invoice" sum="Total Qty To Invoice" optional="hide"/>
                <field name="price_subtotal" string="Untaxed Total" sum="Untaxed Total"/>
                <field name="price_total" string="Total" sum="Total"/>
                <field name="untaxed_amount_invoiced" string="Untaxed Invoiced" sum="Untaxed Invoiced" optional="hide"/>
                <field name="invoice_status" optional="show"/>
                <field name="state" optional="hide"/>
                <field name="currency_id" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <record id="view_sales_analysis_pivot" model="ir.ui.view">
        <field name="name">sales.analysis.pivot</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <pivot string="Sales Analysis" sample="1">
                <field name="date" interval="month" type="row"/>
                <field name="team_id" type="col"/>
                <field name="price_total" type="measure"/>
                <field name="price_subtotal" type="measure"/>
                <field name="product_uom_qty" type="measure"/>
                <field name="qty_delivered" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_sales_analysis_graph" model="ir.ui.view">
        <field name="name">sales.analysis.graph</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <graph string="Sales Analysis" type="bar" sample="1">
                <field name="date" interval="month"/>
                <field name="price_total" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_sales_analysis_preset_search" model="ir.ui.view">
        <field name="name">sales.analysis.preset.search</field>
        <field name="model">sales.analysis.preset</field>
        <field name="arch" type="xml">
            <search string="Sales Analysis Presets">
                <field name="name"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="sales_team_id"/>
                <field name="salesperson_id"/>
                <field name="partner_id"/>
                <field name="product_tmpl_id"/>
                <separator/>
                <filter name="my_presets" string="My Presets" domain="[('user_id', '=', uid)]"/>
                <filter name="shared_presets" string="Shared" domain="[('is_shared', '=', True)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="1" string="Group By">
                    <filter name="group_by_owner" string="Owner" context="{'group_by': 'user_id'}"/>
                    <filter name="group_by_team" string="Sales Team" context="{'group_by': 'sales_team_id'}"/>
                    <filter name="group_by_scope" string="Scope" context="{'group_by': 'state_scope'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sales_analysis_preset_kanban" model="ir.ui.view">
        <field name="name">sales.analysis.preset.kanban</field>
        <field name="model">sales.analysis.preset</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="name"/>
                <field name="color"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="state_scope"/>
                <field name="date_range"/>
                <field name="group_by"/>
                <field name="order_count"/>
                <field name="qty_ordered"/>
                <field name="is_shared"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record rounded-3 border shadow-sm p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <strong class="fs-5">
                                    <field name="name"/>
                                </strong>
                                <span class="badge text-bg-info" t-if="record.is_shared.raw_value">Shared</span>
                            </div>
                            <div class="text-muted small mb-2">
                                <div><strong>Owner:</strong> <field name="user_id"/></div>
                                <div><strong>Period:</strong> <field name="date_range"/></div>
                                <div><strong>Scope:</strong> <field name="state_scope"/></div>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <div class="border rounded p-2 bg-light">
                                        <div class="text-muted small">Orders</div>
                                        <div class="fw-bold" t-esc="record.order_count.value"/>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="border rounded p-2 bg-light">
                                        <div class="text-muted small">Qty Ordered</div>
                                        <div class="fw-bold" t-esc="record.qty_ordered.value"/>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="object" name="action_open_analysis" class="btn btn-primary btn-sm">
                                    Open Analysis
                                </button>
                                <button type="object" name="action_open_summary_page" class="btn btn-outline-secondary btn-sm">
                                    Summary
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_sales_analysis_preset_tree" model="ir.ui.view">
        <field name="name">sales.analysis.preset.tree</field>
        <field name="model">sales.analysis.preset</field>
        <field name="arch" type="xml">
            <tree string="Sales Analysis Presets" default_order="sequence, name">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="user_id"/>
                <field name="is_shared"/>
                <field name="date_range"/>
                <field name="state_scope"/>
                <field name="group_by"/>
                <field name="sales_team_id" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="order_count"/>
                <field name="total_revenue" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_sales_analysis_preset_form" model="ir.ui.view">
        <field name="name">sales.analysis.preset.form</field>
        <field name="model">sales.analysis.preset</field>
        <field name="arch" type="xml">
            <form string="Sales Analysis Preset">
                <header>
                    <button name="action_open_analysis" type="object" string="Open Analysis" class="btn-primary"/>
                    <button name="action_open_summary_page" type="object" string="Open Summary Page" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_analysis" type="object" class="oe_stat_button" icon="fa-line-chart">
                            <field name="order_count" widget="statinfo" string="Orders"/>
                        </button>
                        <button name="action_open_summary_page" type="object" class="oe_stat_button" icon="fa-bar-chart">
                            <div class="o_stat_info">
                                <span class="o_stat_value">
                                    <field name="total_revenue" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">Revenue</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Quarterly enterprise customers"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Ownership">
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="is_shared"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="color" invisible="1"/>
                        </group>
                        <group string="Default Behavior">
                            <field name="date_range"/>
                            <field name="group_by"/>
                            <field name="state_scope"/>
                            <field name="invoice_status"/>
                        </group>
                    </group>
                    <group string="Custom Period" invisible="date_range != 'custom'">
                        <group>
                            <field name="date_from" required="date_range == 'custom'"/>
                            <field name="date_to" required="date_range == 'custom'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Filters">
                            <group>
                                <group>
                                    <field name="sales_team_id"/>
                                    <field name="salesperson_id"/>
                                    <field name="partner_id"/>
                                </group>
                                <group>
                                    <field name="product_tmpl_id"/>
                                    <field name="categ_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Metrics">
                            <group>
                                <group>
                                    <field name="order_count" readonly="1"/>
                                    <field name="qty_ordered" readonly="1"/>
                                    <field name="qty_delivered" readonly="1"/>
                                </group>
                                <group>
                                    <field name="total_revenue" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="untaxed_total" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="qty_to_invoice" readonly="1"/>
                                    <field name="currency_id" invisible="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Document why this preset exists and who should use it."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sales_analysis_overview" model="ir.actions.act_window">
        <field name="name">Overview</field>
        <field name="res_model">sale.report</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="search_view_id" ref="view_sales_analysis_search"/>
        <field name="context">{'search_default_filter_confirmed': 1, 'search_default_current_year': 1, 'search_default_group_by_month': 1, 'group_by_no_leaf': 1}</field>
        <field name="domain">[('state', '!=', 'cancel')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Track sales performance by month, team, product, and customer.
            </p>
            <p>
                Use the filters and grouping shortcuts to spot growth trends,
                top products, and customers that still need invoicing.
            </p>
        </field>
    </record>

    <record id="action_sales_analysis_overview_graph" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_sales_analysis_graph"/>
        <field name="act_window_id" ref="action_sales_analysis_overview"/>
    </record>

    <record id="action_sales_analysis_overview_pivot" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_sales_analysis_pivot"/>
        <field name="act_window_id" ref="action_sales_analysis_overview"/>
    </record>

    <record id="action_sales_analysis_overview_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_sales_analysis_tree"/>
        <field name="act_window_id" ref="action_sales_analysis_overview"/>
    </record>

    <record id="action_sales_analysis_customers" model="ir.actions.act_window">
        <field name="name">By Customer</field>
        <field name="res_model">sale.report</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="search_view_id" ref="view_sales_analysis_search"/>
        <field name="context">{'search_default_filter_confirmed': 1, 'search_default_current_year': 1, 'search_default_group_by_customer': 1, 'group_by_no_leaf': 1}</field>
        <field name="domain">[('state', '=', 'sale')]</field>
    </record>

    <record id="action_sales_analysis_customers_graph" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_sales_analysis_graph"/>
        <field name="act_window_id" ref="action_sales_analysis_customers"/>
    </record>

    <record id="action_sales_analysis_customers_pivot" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_sales_analysis_pivot"/>
        <field name="act_window_id" ref="action_sales_analysis_customers"/>
    </record>

    <record id="action_sales_analysis_customers_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_sales_analysis_tree"/>
        <field name="act_window_id" ref="action_sales_analysis_customers"/>
    </record>

    <record id="action_sales_analysis_products" model="ir.actions.act_window">
        <field name="name">By Product</field>
        <field name="res_model">sale.report</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="search_view_id" ref="view_sales_analysis_search"/>
        <field name="context">{'search_default_filter_confirmed': 1, 'search_default_current_year': 1, 'search_default_group_by_product': 1, 'group_by_no_leaf': 1}</field>
        <field name="domain">[('state', '=', 'sale')]</field>
    </record>

    <record id="action_sales_analysis_products_graph" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_sales_analysis_graph"/>
        <field name="act_window_id" ref="action_sales_analysis_products"/>
    </record>

    <record id="action_sales_analysis_products_pivot" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_sales_analysis_pivot"/>
        <field name="act_window_id" ref="action_sales_analysis_products"/>
    </record>

    <record id="action_sales_analysis_products_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_sales_analysis_tree"/>
        <field name="act_window_id" ref="action_sales_analysis_products"/>
    </record>

    <record id="action_sales_analysis_salespeople" model="ir.actions.act_window">
        <field name="name">By Salesperson</field>
        <field name="res_model">sale.report</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="search_view_id" ref="view_sales_analysis_search"/>
        <field name="context">{'search_default_filter_confirmed': 1, 'search_default_current_year': 1, 'search_default_group_by_salesperson': 1, 'group_by_no_leaf': 1}</field>
        <field name="domain">[('state', '=', 'sale')]</field>
    </record>

    <record id="action_sales_analysis_salespeople_graph" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_sales_analysis_graph"/>
        <field name="act_window_id" ref="action_sales_analysis_salespeople"/>
    </record>

    <record id="action_sales_analysis_salespeople_pivot" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_sales_analysis_pivot"/>
        <field name="act_window_id" ref="action_sales_analysis_salespeople"/>
    </record>

    <record id="action_sales_analysis_salespeople_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_sales_analysis_tree"/>
        <field name="act_window_id" ref="action_sales_analysis_salespeople"/>
    </record>

    <record id="action_sales_analysis_presets" model="ir.actions.act_window">
        <field name="name">Presets</field>
        <field name="res_model">sales.analysis.preset</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_sales_analysis_preset_search"/>
        <field name="context">{'search_default_my_presets': 1, 'default_user_id': uid}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sales analysis preset
            </p>
            <p>
                Presets save your favorite filters and default grouping, so your
                team can reopen the same analysis in one click.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_sales_analysis_root"
        name="Sales Analysis"
        sequence="35"
        groups="sales_analysis.group_sales_analysis_user"
        web_icon="sales_analysis,static/description/icon.png"
        action="action_sales_analysis_overview"
    />

    <menuitem
        id="menu_sales_analysis_overview"
        name="Overview"
        parent="menu_sales_analysis_root"
        action="action_sales_analysis_overview"
        sequence="10"
        groups="sales_analysis.group_sales_analysis_user"
    />

    <menuitem
        id="menu_sales_analysis_customers"
        name="By Customer"
        parent="menu_sales_analysis_root"
        action="action_sales_analysis_customers"
        sequence="20"
        groups="sales_analysis.group_sales_analysis_user"
    />

    <menuitem
        id="menu_sales_analysis_products"
        name="By Product"
        parent="menu_sales_analysis_root"
        action="action_sales_analysis_products"
        sequence="30"
        groups="sales_analysis.group_sales_analysis_user"
    />

    <menuitem
        id="menu_sales_analysis_salespeople"
        name="By Salesperson"
        parent="menu_sales_analysis_root"
        action="action_sales_analysis_salespeople"
        sequence="40"
        groups="sales_analysis.group_sales_analysis_user"
    />

    <menuitem
        id="menu_sales_analysis_presets"
        name="Presets"
        parent="menu_sales_analysis_root"
        action="action_sales_analysis_presets"
        sequence="50"
        groups="sales_analysis.group_sales_analysis_user"
    />
</odoo>
