<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_sales_analysis_user" model="res.groups">
        <field name="name">Sales Analyst</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_sales_analysis_manager" model="res.groups">
        <field name="name">Sales Analysis Manager</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="implied_ids" eval="[(4, ref('sales_analysis.group_sales_analysis_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin')), (4, ref('base.user_root'))]"/>
    </record>

    <record id="sales_team.group_sale_salesman" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('sales_analysis.group_sales_analysis_user'))]"/>
    </record>

    <record id="sales_team.group_sale_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('sales_analysis.group_sales_analysis_manager'))]"/>
    </record>

    <data noupdate="1">
        <record id="sales_analysis_rule_preset_user" model="ir.rule">
            <field name="name">Sales analysis presets: own or shared</field>
            <field name="model_id" ref="model_sales_analysis_preset"/>
            <field name="groups" eval="[Command.link(ref('sales_analysis.group_sales_analysis_user'))]"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('is_shared', '=', True)]</field>
        </record>

        <record id="sales_analysis_rule_preset_manager" model="ir.rule">
            <field name="name">Sales analysis presets: managers can access all</field>
            <field name="model_id" ref="model_sales_analysis_preset"/>
            <field name="groups" eval="[Command.link(ref('sales_analysis.group_sales_analysis_manager'))]"/>
        </record>

        <record id="sales_analysis_rule_preset_company" model="ir.rule">
            <field name="name">Sales analysis presets: multi-company</field>
            <field name="model_id" ref="model_sales_analysis_preset"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
        </record>
    </data>
</odoo>
