<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_mc_report_sales_summary" model="ir.actions.client">
        <field name="name">Báo cáo Tổng hợp Bán hàng</field>
        <field name="tag">mc_reporting.report</field>
        <field name="params" eval="{'report_type': 'sales_summary'}"/>
    </record>

    <record id="action_mc_report_sales_channel" model="ir.actions.client">
        <field name="name">Báo cáo Bán hàng theo Kênh</field>
        <field name="tag">mc_reporting.report</field>
        <field name="params" eval="{'report_type': 'sales_channel'}"/>
