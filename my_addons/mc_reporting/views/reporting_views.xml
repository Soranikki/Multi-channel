    <record id="action_mc_report_best_selling" model="ir.actions.client">
        <field name="name">Báo cáo Sản phẩm Bán chạy</field>
        <field name="tag">mc_reporting.report</field>
        <field name="params" eval="{'report_type': 'best_selling'}"/>
    </record>

    <record id="action_mc_report_inventory" model="ir.actions.client">
        <field name="name">Báo cáo Tồn kho</field>
        <field name="tag">mc_reporting.report</field>
        <field name="params" eval="{'report_type': 'inventory'}"/>
    </record>

    <record id="action_mc_report_sync_status" model="ir.actions.client">
        <field name="name">Báo cáo Đồng bộ Tồn kho</field>
        <field name="tag">mc_reporting.report</field>
        <field name="params" eval="{'report_type': 'sync_status'}"/>
    </record>

    <record id="action_mc_report_order_list" model="ir.actions.client">
        <field name="name">Báo cáo Danh sách Đơn hàng</field>
        <field name="tag">mc_reporting.report</field>
        <field name="params" eval="{'report_type': 'order_list'}"/>
    </record>
</odoo>
