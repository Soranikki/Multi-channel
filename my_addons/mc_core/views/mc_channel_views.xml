<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mc_channel_tree" model="ir.ui.view">
        <field name="name">mc.channel.tree</field>
        <field name="model">mc.channel</field>
        <field name="arch" type="xml">
            <tree string="Sales Channels" decoration-muted="active == False">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="sync_status" widget="badge"/>
                <field name="last_sync_at"/>
                <field name="active" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <record id="view_mc_channel_form" model="ir.ui.view">
        <field name="name">mc.channel.form</field>
        <field name="model">mc.channel</field>
        <field name="arch" type="xml">
            <form string="Sales Channel">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_sync_logs" type="object" class="oe_stat_button" icon="fa-list">
                            <div class="o_stat_info"><span class="o_stat_text">Sync Logs</span></div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="sync_status"/>
                            <field name="last_sync_at"/>
                            <field name="last_sync_duration"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Channel notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mc_channel" model="ir.actions.act_window">
        <field name="name">Sales Channels</field>
        <field name="res_model">mc.channel</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_mc_channels" name="Sales Channels" parent="mc_core.menu_mc_configuration" action="mc_core.action_mc_channel" sequence="10" groups="mc_core.group_mc_manager"/>
</odoo>
