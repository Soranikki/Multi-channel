<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mc_channel_tree" model="ir.ui.view">
        <field name="name">mc.channel.tree</field>
        <field name="model">mc.channel</field>
        <field name="arch" type="xml">
            <tree string="Kênh bán hàng" decoration-muted="active == False">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="sync_status" widget="badge"/>
                <field name="last_sync_at"/>
                <field name="active" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <record id="view_mc_channel_form" model="ir.ui.view">
        <field name="name">mc.channel.form</field>
        <field name="model">mc.channel</field>
        <field name="arch" type="xml">
            <form string="Sales Channel">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_sync_logs" type="object" class="oe_stat_button" icon="fa-list">
                            <div class="o_stat_info"><span class="o_stat_text">Sync Logs</span></div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="sync_status"/>
                            <field name="last_sync_at"/>
                            <field name="last_sync_duration"/>
                        </group>
                    </group>
                    <group string="Platform">
                        <field name="platform_icon" filename="platform_icon_filename"/>
                        <field name="platform_icon_filename" invisible="1"/>
                    </group>
                    <field name="description" placeholder="Channel notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mc_channel_search" model="ir.ui.view">
        <field name="name">mc.channel.search</field>
        <field name="model">mc.channel</field>
        <field name="arch" type="xml">
            <search string="Search Channels">
                <field name="name" string="Channel Name"/>
                <field name="code" string="Platform"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
                <separator/>
                <filter name="shopee" string="Shopee" domain="[('code','=','shopee')]"/>
                <filter name="tiktok" string="TikTok" domain="[('code','=','tiktok')]"/>
                <filter name="manual" string="Manual" domain="[('code','=','manual')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_code" string="Platform" context="{'group_by': 'code'}"/>
                    <filter name="group_by_status" string="Sync Status" context="{'group_by': 'sync_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_mc_channel" model="ir.actions.act_window">
        <field name="name">Kênh bán hàng</field>
        <field name="res_model">mc.channel</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_mc_channel_search"/>
    </record>

    <menuitem id="menu_mc_channels" name="Kênh bán hàng" parent="mc_core.menu_mc_configuration" action="mc_core.action_mc_channel" sequence="10" groups="mc_core.group_mc_manager"/>
</odoo>
