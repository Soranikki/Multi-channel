<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mc_integration_service_tree" model="ir.ui.view">
        <field name="name">mc.integration.service.tree</field>
        <field name="model">mc.integration.service</field>
        <field name="arch" type="xml">
            <tree string="Dịch vụ tích hợp">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="base_url"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_mc_integration_service_form" model="ir.ui.view">
        <field name="name">mc.integration.service.form</field>
        <field name="model">mc.integration.service</field>
        <field name="arch" type="xml">
            <form string="Integration Service">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="base_url"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mc_integration_service_search" model="ir.ui.view">
        <field name="name">mc.integration.service.search</field>
        <field name="model">mc.integration.service</field>
        <field name="arch" type="xml">
            <search string="Dịch vụ tích hợp">
                <field name="name"/>
                <field name="code"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="inactive" string="Inactive" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_mc_integration_service" model="ir.actions.act_window">
        <field name="name">Dịch vụ tích hợp</field>
        <field name="res_model">mc.integration.service</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_mc_integration_service_search"/>
        <field name="help" type="html">
            <p>Configure URLs for external services that Odoo connects to.</p>
            <p>The <b>Odoo WS Connector</b> URL is required for channel archive/reactivate to work.</p>
        </field>
    </record>

    <menuitem id="menu_mc_integration_service" name="Dịch vụ tích hợp"
              parent="menu_mc_configuration" sequence="50"
              action="action_mc_integration_service" groups="mc_core.group_mc_manager"/>
</odoo>
