<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mc_sync_log_search" model="ir.ui.view">
        <field name="name">mc.sync.log.search</field>
        <field name="model">mc.sync.log</field>
        <field name="arch" type="xml">
            <search string="Lịch sử đồng bộ">
                <field name="channel_id"/>
                <field name="reference"/>
                <filter name="errors" string="Errors" domain="[('log_type','=','error')]"/>
                <filter name="warnings" string="Warnings" domain="[('log_type','=','warning')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_channel" string="Channel" context="{'group_by': 'channel_id'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'log_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_mc_sync_log_tree" model="ir.ui.view">
        <field name="name">mc.sync.log.tree</field>
        <field name="model">mc.sync.log</field>
        <field name="arch" type="xml">
            <tree string="Lịch sử đồng bộ" create="false" edit="false" delete="false" decoration-danger="log_type == 'error'" decoration-warning="log_type == 'warning'">
                <field name="timestamp"/>
                <field name="channel_id"/>
                <field name="log_type" widget="badge"/>
                <field name="reference"/>
                <field name="message"/>
            </tree>
        </field>
    </record>

    <record id="view_mc_sync_log_form" model="ir.ui.view">
        <field name="name">mc.sync.log.form</field>
        <field name="model">mc.sync.log</field>
        <field name="arch" type="xml">
            <form string="Sync Log" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <field name="timestamp"/>
                        <field name="channel_id"/>
                        <field name="log_type"/>
                        <field name="reference"/>
                    </group>
                    <field name="message"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mc_sync_log" model="ir.actions.act_window">
        <field name="name">Lịch sử đồng bộ</field>
        <field name="res_model">mc.sync.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_mc_sync_log_search"/>
    </record>

    <menuitem id="menu_mc_sync_log" name="All Lịch sử đồng bộ" parent="mc_core.menu_mc_logs" action="mc_core.action_mc_sync_log" sequence="10" groups="mc_core.group_mc_user"/>
</odoo>
