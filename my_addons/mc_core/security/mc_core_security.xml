<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_multichannel" model="ir.module.category">
            <field name="name">Multichannel Sales</field>
            <field name="sequence">90</field>
        </record>

        <record id="group_mc_user" model="res.groups">
            <field name="name">Multichannel User</field>
            <field name="category_id" ref="module_category_multichannel"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_mc_manager" model="res.groups">
            <field name="name">Multichannel Manager</field>
            <field name="category_id" ref="module_category_multichannel"/>
            <field name="implied_ids" eval="[(4, ref('group_mc_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
