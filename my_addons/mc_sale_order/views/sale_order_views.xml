<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_mc" model="ir.ui.view">
        <field name="name">sale.order.form.mc</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_mc_raw_order" type="object" class="oe_stat_button" icon="fa-inbox" invisible="not mc_raw_order_id">
                    <div class="o_stat_info"><span class="o_stat_text">Raw Order</span></div>
                </button>
            </xpath>
            <xpath expr="//field[@name='client_order_ref']" position="after">
                <field name="mc_channel_id"/>
                <field name="mc_external_order_id"/>
                <field name="mc_raw_order_id" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_id']" position="after">
                <field name="mc_external_sku" readonly="1" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_sale_order_tree_mc" model="ir.ui.view">
        <field name="name">sale.order.tree.mc</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="mc_channel_id" optional="show"/>
                <field name="mc_external_order_id" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_sale_order_search_mc" model="ir.ui.view">
        <field name="name">sale.order.search.mc</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="mc_channel_id"/>
                <field name="mc_external_order_id"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter string="Channel" name="group_mc_channel" context="{'group_by': 'mc_channel_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="action_mc_sale_order" model="ir.actions.act_window">
        <field name="name">Multichannel Sales Orders</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">tree,form,kanban,calendar,pivot,graph</field>
        <field name="search_view_id" ref="view_sale_order_search_mc"/>
        <field name="domain">[('mc_channel_id', '!=', False)]</field>
        <field name="context">{'search_default_group_mc_channel': 1}</field>
    </record>
</odoo>
